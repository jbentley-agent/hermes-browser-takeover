-        return session
+
+    # Auto-reattach: if local tab state is missing, probe the backend for an
+    # existing live tab before declaring the session gone. This covers cases
+    # where Python-side bookkeeping was cleaned up but the Camofox backend is
+    # still holding the browser/tab open. Without this, snapshot/click would
+    # fail with "No browser session" even though the backend can still serve
+    # the live page.
+    session = _sessions[task_id]
+    if not session["tab_id"]:
+        try:
+            base = get_camofox_url()
+            resp = requests.get(
+                f"{base}/tabs",
+                params={"userId": session["user_id"]},
+                timeout=5,
+            )
+            if resp.status_code == 200:
+                tabs = resp.json().get("tabs", [])
+                if tabs:
+                    reused_tab = tabs[-1]
+                    session["tab_id"] = reused_tab.get("tabId") or reused_tab.get("targetId")
+                    logger.info(
+                        "Auto-reattached to existing tab %s (url: %s)",
+                        session["tab_id"],
+                        reused_tab.get("url", "?"),
+                    )
+        except Exception as exc:
+            logger.debug("Auto-reattach check failed: %s", exc)
+
+    return session
 
 
